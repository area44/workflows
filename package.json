    "url": "git+https://github.com/area44/workflows.git"
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
